{
    "$schema":  "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
    "productName":  "Reckon Bolt",
    "version": "1.0.1",
    "identifier":  "com.reckon.bolt",
    "build":  {
                  "frontendDist":  "../src"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Reckon Bolt",
                                    "width":  1024,
                                    "height":  768,
                                    "center":  true
                                }
                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027; style-src \u0027self\u0027 \u0027unsafe-inline\u0027"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               }
}